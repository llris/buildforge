PORT=5000
DATABASE_URL="postgresql://user:pass@localhost:5432/buildforge"
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
CLIENT_URL="http://localhost:5173"

# Ethereal Email (Development)
# Note: If SMTP_USER and SMTP_PASS are left blank, the app will automatically
# call nodemailer.createTestAccount() to generate a working Ethereal account.
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@buildforge.com"
